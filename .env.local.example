# ============================================================
# Rayve — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never exposed to browser

# ── App URL ───────────────────────────────────────────────────
# Dev: http://localhost:3000
# Prod: https://your-project.vercel.app  (or custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI — Anthropic Claude ────────────────────────────────────
# Required for chat workspace. Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram Login (optional) ────────────────────────────────
# Create bot via @BotFather in Telegram. /newbot → get token.
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=   # bot username without @

# ── Facebook App (optional) ──────────────────────────────────
# Required for: Facebook login, Meta Ads campaign activation.
# Create at: https://developers.facebook.com → Create App → Consumer
# Add products: Facebook Login, Marketing API, Facebook Login for Business
# Valid OAuth Redirect URIs to add in FB app settings:
#   https://<supabase-ref>.supabase.co/auth/v1/callback   (for FB login via Supabase)
#   http://localhost:3000/api/meta/callback                (for Meta Ads, dev)
#   https://<your-domain>/api/meta/callback                (for Meta Ads, prod)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/meta/callback
